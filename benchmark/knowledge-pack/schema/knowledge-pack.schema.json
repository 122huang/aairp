{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aairp.local/schemas/knowledge-pack.schema.json",
  "title": "Knowledge Pack v2",
  "type": "object",
  "required": [
    "schema_version",
    "knowledge_pack_id",
    "knowledge_pack_version",
    "knowledge_pack_fingerprint",
    "platform_version",
    "generated_at",
    "release_status",
    "corpora",
    "dependency_graph",
    "runtime_components",
    "evaluation_linkage",
    "compatibility",
    "ownership_summary"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "knowledge_pack_id": {
      "type": "string",
      "pattern": "^kp-\\d{4}\\.\\d{2}\\.\\d+$"
    },
    "knowledge_pack_version": { "type": "string" },
    "knowledge_pack_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "platform_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "release_status": {
      "enum": ["draft", "validated", "released", "deprecated"]
    },
    "released_at": { "type": "string", "format": "date-time" },
    "released_by": { "type": "string" },
    "supersedes": { "type": "string" },
    "deprecated_reason": { "type": "string" },
    "corpora": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "corpus_type",
          "manifest_path",
          "schema_version",
          "fingerprint",
          "entry_count",
          "knowledge_quality_score",
          "manifest_generated_at",
          "validation"
        ],
        "properties": {
          "corpus_type": { "type": "string" },
          "manifest_path": { "type": "string" },
          "schema_version": { "type": "string" },
          "fingerprint": { "type": "string" },
          "entry_count": { "type": "integer", "minimum": 0 },
          "knowledge_quality_score": { "type": "number" },
          "manifest_generated_at": { "type": "string" },
          "validation": {
            "type": "object",
            "properties": {
              "errors": { "type": "integer" },
              "warnings": { "type": "integer" }
            }
          }
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "required": ["frozen_at", "nodes", "edges", "orphan_counts"],
      "properties": {
        "frozen_at": { "type": "string", "format": "date-time" },
        "nodes": { "type": "object" },
        "edges": { "type": "object" },
        "orphan_counts": { "type": "object" }
      }
    },
    "runtime_components": { "type": "object" },
    "evaluation_linkage": { "type": "object" },
    "compatibility": { "type": "object" },
    "ownership_summary": { "type": "object" }
  },
  "additionalProperties": false
}
