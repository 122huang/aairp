{
  "name": "@aairp/application",
  "version": "0.1.0-sprint1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "eval:benchmark": "pnpm build && node dist/evaluation/run-benchmark.js",
    "eval:dataset": "pnpm build && node dist/evaluation/run-dataset-eval.js"
  },
  "dependencies": {
    "@aairp/domain": "workspace:*",
    "@aairp/shared-kernel": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
