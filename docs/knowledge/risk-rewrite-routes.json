      "rewrite_template_id": "disclose-localization",
      "strategy": "rephrase",
      "rule_ids": ["demo-apac-sa-localization", "demo-apac-sa-localization-cjk"]
    },
    {
      "risk_type": "ai-image-disclaimer",
      "rewrite_template_id": "disclose-ai",
      "strategy": "append",
      "rule_ids": ["demo-apac-sa-ai-image-disclaimer"]
    },
    {
      "risk_type": "capacity-claim",
      "rewrite_template_id": "qualify-performance",
      "strategy": "qualify",
      "rule_ids": ["demo-apac-sa-capacity-claim"]
