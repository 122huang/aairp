# Copy to .env and adjust for local development.
# Required for apps/api startup (health + ready probes).

DATABASE_URL=postgresql://aairp:aairp@localhost:5432/aairp
REDIS_URL=redis://localhost:6379

# Optional
HOST=0.0.0.0
PORT=3000
SERVICE_NAME=aairp-api
APP_VERSION=0.1.0-sprint1.5
DEFAULT_TENANT_ID=demo

# Google Cloud Vision — optional cloud OCR
GOOGLE_VISION_API_KEY=

# Local PaddleOCR (recommended in CN — no Google/Claude card needed)
# Run once: .\scripts\setup-paddle-ocr.ps1
OCR_PROVIDER=paddle
PADDLE_OCR_ENABLED=1
# PADDLE_PYTHON=C:\Users\...\aairp\.venv-paddle\Scripts\python.exe
# English-only export banners: PADDLE_OCR_LANG=en
# OCR tuning for steam/glare on white copy (defaults shown)
# OCR_UPSCALE_FACTOR=2.0
# OCR_CONTRAST=1.35
# OCR_SHARPNESS=1.5

# Smart extract: browser OCR draft + LLM text cleanup (choose one text provider)
# DeepSeek (recommended for text cleanup — hosted API is text-only, no image input)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OCR_TEXT_PROVIDER=deepseek
OCR_VISION_PROVIDER=deepseek
OCR_LLM_MODEL=deepseek-v4-flash

# Optional vision LLM (image + OCR reconcile) — Anthropic or OpenAI only
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Open Risk — semantic LLM layer (after Rule + Playbook). Requires explicit opt-in:
AAIRP_OPEN_RISK_MODE=live
OPEN_RISK_LLM_PROVIDER=deepseek
# Reuse DEEPSEEK_API_KEY from OCR section above, or set ANTHROPIC_API_KEY / OPENAI_API_KEY
OPEN_RISK_TIMEOUT_MS=45000
OPEN_RISK_MAX_RETRIES=1
OPEN_RISK_MAX_TOKENS=2048

# Vision — multimodal image compliance (SiliconFlow DeepSeek-VL2)
# Modes: off (default) | stub (demo/CI) | live
AAIRP_VISION_MODE=stub
VISION_LLM_BASE_URL=https://api.siliconflow.cn/v1
VISION_LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
VISION_LLM_API_KEY=
# Fallback if VISION_LLM_API_KEY unset: DEEPSEEK_API_KEY
VISION_TIMEOUT_MS=60000
VISION_MAX_RETRIES=1
VISION_MAX_TOKENS=2048

