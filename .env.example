# Copy to .env and adjust for local development.
# Required for apps/api startup (health + ready probes).

DATABASE_URL=postgresql://aairp:aairp@localhost:5432/aairp
REDIS_URL=redis://localhost:6379

# Optional
HOST=0.0.0.0
PORT=3000
SERVICE_NAME=aairp-api
APP_VERSION=0.1.0-sprint1.5
DEFAULT_TENANT_ID=demo

# Open Risk Discovery (Sprint 1.5)
OPEN_RISK_TIMEOUT_MS=5000
OPEN_RISK_MAX_RETRIES=1
