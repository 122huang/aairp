{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build:review-app",
  "outputDirectory": "apps/review-app/dist",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "destination": "/review/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/demo/:path*",
      "destination": "https://REPLACE_WITH_API_HOST/demo/:path*"
    },
    {
      "source": "/health",
      "destination": "https://REPLACE_WITH_API_HOST/health"
    },
    {
      "source": "/ready",
      "destination": "https://REPLACE_WITH_API_HOST/ready"
    },
    {
      "source": "/review",
      "destination": "/review/index.html"
    }
  ],
  "headers": [
    {
      "source": "/review/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
